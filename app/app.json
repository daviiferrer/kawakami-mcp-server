{
  "$schema": "https://opencode.ai/app.json",
  "name": "kawakami-mercado",
  "version": "1.0.0",
  "description": "Consulte precos e ofertas do Supermercados Kawakami. Planeje suas compras com fotos dos produtos.",
  "icon": "https://www.kawakami.com.br/assets/images/favicon.png",
  "widgets": {
    "product-card": {
      "type": "card",
      "schema": {
        "type": "object",
        "properties": {
          "imagem": { "type": "string", "description": "URL da imagem do produto" },
          "nome": { "type": "string", "description": "Nome do produto" },
          "preco": { "type": "number", "description": "Preco normal" },
          "preco_oferta": { "type": "number", "description": "Preco em oferta" },
          "preco_antigo": { "type": "number", "description": "Preco anterior a oferta" },
          "desconto": { "type": "number", "description": "Percentual de desconto" },
          "tag_oferta": { "type": "string", "description": "Tag da oferta" },
          "estoque": { "type": "integer", "description": "Quantidade em estoque" },
          "unidade": { "type": "string", "description": "Unidade de medida" },
          "disponivel": { "type": "boolean", "description": "Se esta disponivel" },
          "ean": { "type": "string", "description": "Codigo de barras" },
          "produto_id": { "type": "integer" }
        }
      },
      "template": {
        "style": {
          "card": {
            "borderRadius": "8px",
            "overflow": "hidden",
            "boxShadow": "0 2px 8px rgba(0,0,0,0.1)",
            "background": "#ffffff",
            "width": "280px",
            "fontFamily": "Roboto, sans-serif"
          },
          "image": {
            "width": "100%",
            "height": "200px",
            "objectFit": "contain",
            "background": "#f5f5f5"
          },
          "badge": {
            "position": "absolute",
            "top": "8px",
            "left": "8px",
            "padding": "4px 8px",
            "borderRadius": "4px",
            "fontSize": "10px",
            "fontWeight": "bold",
            "textTransform": "uppercase",
            "color": "#ffffff"
          },
          "badge-black": { "background": "#2f3138" },
          "badge-orange": { "background": "#f97316" },
          "badge-green": { "background": "#138d45" },
          "body": {
            "padding": "12px"
          },
          "name": {
            "fontSize": "14px",
            "fontWeight": "500",
            "color": "#2f3138",
            "marginBottom": "8px",
            "lineHeight": "1.3",
            "overflow": "hidden",
            "textOverflow": "ellipsis",
            "display": "-webkit-box",
            "lineClamp": "2"
          },
          "price_normal": {
            "fontSize": "20px",
            "fontWeight": "bold",
            "color": "#2f3138"
          },
          "price_offer": {
            "fontSize": "24px",
            "fontWeight": "bold",
            "color": "#138d45"
          },
          "price_old": {
            "fontSize": "14px",
            "color": "#9e9e9e",
            "textDecoration": "line-through"
          },
          "discount_badge": {
            "background": "#138d45",
            "color": "#ffffff",
            "padding": "2px 6px",
            "borderRadius": "4px",
            "fontSize": "12px",
            "fontWeight": "bold",
            "marginLeft": "8px"
          },
          "stock": {
            "fontSize": "12px",
            "color": "#545454",
            "marginTop": "4px"
          },
          "unidade": {
            "fontSize": "14px",
            "color": "#545454"
          }
        },
        "layout": "<div class='card'><div style='position:relative'><img class='image' src='{imagem}'/><span class='badge badge-{tag_color}'>{tag_oferta}</span></div><div class='body'><div class='name'>{nome}</div><div><span class='price_offer'>R$ {preco_oferta}</span><span class='discount_badge'>{desconto}% OFF</span></div><div><span class='price_old'>R$ {preco_antigo}</span><span class='unidade'>/{unidade}</span></div><div class='stock'>Estoque: {estoque} | EAN: {ean}</div></div></div>"
      }
    },
    "product-list": {
      "type": "list",
      "schema": {
        "type": "array",
        "items": { "$ref": "#/widgets/product-card/schema" }
      },
      "template": {
        "style": {
          "container": {
            "display": "flex",
            "flexWrap": "wrap",
            "gap": "16px",
            "padding": "16px",
            "overflowY": "auto",
            "maxHeight": "600px"
          }
        },
        "layout": "<div class='container'>{items}</div>",
        "itemTemplate": "{product-card}"
      }
    },
    "shopping-list": {
      "type": "card",
      "schema": {
        "type": "object",
        "properties": {
          "titulo": { "type": "string" },
          "itens": { 
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "nome": { "type": "string" },
                "preco": { "type": "number" },
                "unidade": { "type": "string" },
                "imagem": { "type": "string" }
              }
            }
          },
          "total": { "type": "number" },
          "cep": { "type": "string" }
        }
      },
      "template": {
        "style": {
          "card": {
            "background": "#ffffff",
            "borderRadius": "12px",
            "boxShadow": "0 4px 16px rgba(0,0,0,0.08)",
            "overflow": "hidden",
            "fontFamily": "Roboto, sans-serif",
            "maxWidth": "400px"
          },
          "header": {
            "background": "linear-gradient(135deg, #138d45, #005e1b)",
            "color": "#ffffff",
            "padding": "16px",
            "fontSize": "18px",
            "fontWeight": "bold"
          },
          "item": {
            "display": "flex",
            "alignItems": "center",
            "padding": "12px 16px",
            "borderBottom": "1px solid #f0f0f0",
            "gap": "12px"
          },
          "itemImage": {
            "width": "48px",
            "height": "48px",
            "borderRadius": "6px",
            "objectFit": "cover",
            "background": "#f5f5f5"
          },
          "itemName": {
            "flex": "1",
            "fontSize": "14px",
            "color": "#2f3138"
          },
          "itemPrice": {
            "fontSize": "16px",
            "fontWeight": "bold",
            "color": "#138d45"
          },
          "total": {
            "padding": "16px",
            "textAlign": "right",
            "fontSize": "20px",
            "fontWeight": "bold",
            "color": "#138d45",
            "borderTop": "2px solid #a5c83f"
          }
        },
        "layout": "<div class='card'><div class='header'>🛒 {titulo} - CEP {cep}</div>{items_html}<div class='total'>Total: R$ {total}</div></div>"
      }
    }
  }
}
