# Kawakami MCP Server — Environment Variables
# Copie este arquivo para .env e preencha os valores

# ── VIP Commerce (API do supermercado) ──
# Token JWT da sessao anonima (obtido via browser na primeira vez)
KWK_VIP_TOKEN=
# Session ID que acompanha o token
KWK_VIP_SESSAO_ID=
# Credenciais anônimas para renovação: "usuario:chave;usuario2:chave2"
KWK_VIP_FALLBACK_CREDS=
# Arquivo persistente para token renovado
# KWK_TOKEN_FILE_PATH=/var/lib/kawakami-mcp/.kawakami_token.json
# Timeout das chamadas HTTP (segundos)
# KWK_VIP_TIMEOUT_CONNECT=10.0
# KWK_VIP_TIMEOUT_READ=30.0

# ── Retry ──
# KWK_RETRY_MAX_ATTEMPTS=3
# KWK_RETRY_BACKOFF_BASE=1.5

# ── Server ──
# KWK_HOST=0.0.0.0
# KWK_PORT=8000
# KWK_LOG_LEVEL=ERROR

# ── Defaults ──
# CEP padrao para precificacao
# KWK_DEFAULT_CEP=19700000
# CD padrao (9 = Paraguacu Paulista)
# KWK_DEFAULT_CD_ID=9
# Origem HTTPS dedicada usada pelo widget MCP Apps
# KWK_WIDGET_DOMAIN=https://kawakami.axischat.com.br

# ── Sessao ──
# KWK_SESSION_TTL_HOURS=24
# Caminho do SQLite persistente
# KWK_SESSION_DB_PATH=/var/lib/kawakami-mcp/kawakami_sessions.db
